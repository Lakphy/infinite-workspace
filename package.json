{
  "name": "infinite-workspace",
  "displayName": "Infinite Workspace",
  "description": "An infinite canvas workspace with draggable terminal, browser, and file explorer windows — supports VS Code Desktop & Web",
  "version": "0.1.0",
  "publisher": "lakphy",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lakphy/infinite-workspace"
  },
  "homepage": "https://github.com/Lakphy/infinite-workspace#readme",
  "bugs": {
    "url": "https://github.com/Lakphy/infinite-workspace/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "infinite canvas",
    "workspace",
    "terminal",
    "browser",
    "multi-window",
    "productivity",
    "codespace"
  ],
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Terminal and file system features are disabled in untrusted workspaces."
    }
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "infinite-workspace.open",
        "title": "Open Infinite Workspace",
        "category": "Infinite Workspace"
      }
    ],
    "configuration": {
      "title": "Infinite Workspace",
      "properties": {
        "infinite-workspace.openOnStartup": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open Infinite Workspace when VS Code starts."
        },
        "infinite-workspace.colorMode": {
          "type": "string",
          "enum": [
            "dark",
            "light"
          ],
          "description": "Color mode for the workspace UI and embedded browser windows. Auto-detected from your VS Code theme on first launch."
        },
        "infinite-workspace.canvas.showGrid": {
          "type": "boolean",
          "default": true,
          "description": "Show background dot grid on the canvas."
        },
        "infinite-workspace.canvas.minScale": {
          "type": "number",
          "default": 0.05,
          "minimum": 0.01,
          "maximum": 1,
          "description": "Minimum zoom scale for the canvas."
        },
        "infinite-workspace.canvas.maxScale": {
          "type": "number",
          "default": 8,
          "minimum": 1,
          "maximum": 20,
          "description": "Maximum zoom scale for the canvas."
        },
        "infinite-workspace.canvas.zoomSpeed": {
          "type": "number",
          "default": 0.08,
          "minimum": 0.01,
          "maximum": 0.5,
          "description": "Zoom speed factor for scroll wheel zooming."
        },
        "infinite-workspace.canvas.lerpFactor": {
          "type": "number",
          "default": 0.18,
          "minimum": 0.01,
          "maximum": 1,
          "description": "Animation interpolation factor (higher = snappier, lower = smoother)."
        },
        "infinite-workspace.canvas.gridSpacing": {
          "type": "number",
          "default": 40,
          "minimum": 10,
          "maximum": 200,
          "description": "Base spacing (in canvas pixels) between grid dots."
        },
        "infinite-workspace.snap.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable snap-to-alignment guides when dragging windows."
        },
        "infinite-workspace.snap.threshold": {
          "type": "number",
          "default": 8,
          "minimum": 2,
          "maximum": 30,
          "description": "Snap distance in screen pixels for alignment guides."
        },
        "infinite-workspace.defaultSize.terminal.width": {
          "type": "number",
          "default": 650,
          "minimum": 100,
          "maximum": 3000,
          "description": "Default width for new terminal windows."
        },
        "infinite-workspace.defaultSize.terminal.height": {
          "type": "number",
          "default": 380,
          "minimum": 100,
          "maximum": 3000,
          "description": "Default height for new terminal windows."
        },
        "infinite-workspace.defaultSize.browser.width": {
          "type": "number",
          "default": 750,
          "minimum": 100,
          "maximum": 3000,
          "description": "Default width for new browser windows."
        },
        "infinite-workspace.defaultSize.browser.height": {
          "type": "number",
          "default": 520,
          "minimum": 100,
          "maximum": 3000,
          "description": "Default height for new browser windows."
        },
        "infinite-workspace.defaultSize.fileExplorer.width": {
          "type": "number",
          "default": 700,
          "minimum": 100,
          "maximum": 3000,
          "description": "Default width for new file explorer windows."
        },
        "infinite-workspace.defaultSize.fileExplorer.height": {
          "type": "number",
          "default": 480,
          "minimum": 100,
          "maximum": 3000,
          "description": "Default height for new file explorer windows."
        },
        "infinite-workspace.defaultSize.agent.width": {
          "type": "number",
          "default": 700,
          "minimum": 100,
          "maximum": 3000,
          "description": "Default width for new agent windows."
        },
        "infinite-workspace.defaultSize.agent.height": {
          "type": "number",
          "default": 500,
          "minimum": 100,
          "maximum": 3000,
          "description": "Default height for new agent windows."
        },
        "infinite-workspace.agent.model": {
          "type": "string",
          "default": "",
          "description": "Claude model to use (e.g. 'claude-sonnet-4-20250514'). Leave empty for default."
        },
        "infinite-workspace.agent.permissionMode": {
          "type": "string",
          "default": "bypassPermissions",
          "enum": [
            "default",
            "acceptEdits",
            "bypassPermissions"
          ],
          "enumDescriptions": [
            "Normal permission mode — prompts for dangerous operations",
            "Auto-accept file edits, prompt for other operations",
            "Bypass all permissions — agent operates autonomously"
          ],
          "description": "Permission mode for the agent session."
        },
        "infinite-workspace.agent.maxTurns": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 1000,
          "description": "Maximum agentic turns (tool-use round trips). 0 = unlimited."
        },
        "infinite-workspace.agent.maxBudgetUsd": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Maximum budget in USD for a single query. 0 = unlimited."
        },
        "infinite-workspace.agent.effort": {
          "type": "string",
          "default": "high",
          "enum": [
            "low",
            "medium",
            "high",
            "max"
          ],
          "description": "How much effort Claude puts into its response."
        },
        "infinite-workspace.agent.customSystemPrompt": {
          "type": "string",
          "default": "",
          "description": "Additional instructions appended to Claude Code's system prompt."
        },
        "infinite-workspace.agent.allowedTools": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Tools to auto-approve without prompting (e.g. ['Bash', 'Read']). Empty = use permissionMode."
        },
        "infinite-workspace.agent.disallowedTools": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Tools to always deny (e.g. ['WebFetch']). Overrides allowedTools and permissionMode."
        },
        "infinite-workspace.window.minWidth": {
          "type": "number",
          "default": 200,
          "minimum": 50,
          "maximum": 500,
          "description": "Minimum width when resizing windows."
        },
        "infinite-workspace.window.minHeight": {
          "type": "number",
          "default": 150,
          "minimum": 50,
          "maximum": 500,
          "description": "Minimum height when resizing windows."
        },
        "infinite-workspace.terminal.fontSize": {
          "type": "number",
          "default": 12,
          "minimum": 6,
          "maximum": 36,
          "description": "Font size for terminals in the workspace."
        },
        "infinite-workspace.terminal.lineHeight": {
          "type": "number",
          "default": 1.1,
          "minimum": 0.8,
          "maximum": 3,
          "description": "Line height for terminals in the workspace."
        },
        "infinite-workspace.terminal.letterSpacing": {
          "type": "number",
          "default": 0,
          "minimum": -5,
          "maximum": 10,
          "description": "Letter spacing for terminals in the workspace."
        },
        "infinite-workspace.terminal.fontFamily": {
          "type": "string",
          "default": "Menlo, Monaco, \"Courier New\", monospace",
          "description": "Font family for terminals in the workspace."
        },
        "infinite-workspace.terminal.cursorBlink": {
          "type": "boolean",
          "default": true,
          "description": "Whether the terminal cursor blinks."
        },
        "infinite-workspace.terminal.cursorStyle": {
          "type": "string",
          "default": "block",
          "enum": [
            "block",
            "underline",
            "bar"
          ],
          "description": "Terminal cursor style."
        },
        "infinite-workspace.terminal.scrollback": {
          "type": "number",
          "default": 5000,
          "minimum": 100,
          "maximum": 100000,
          "description": "Number of scrollback lines to retain in terminal history."
        },
        "infinite-workspace.terminal.shell": {
          "type": "string",
          "default": "",
          "description": "Override the default shell for terminals. Leave empty to use system default ($SHELL or PowerShell on Windows)."
        },
        "infinite-workspace.favorites.terminalCommands": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "properties": {
              "value": {
                "type": "string",
                "description": "The command to run."
              },
              "width": {
                "type": "number",
                "description": "Optional custom window width."
              },
              "height": {
                "type": "number",
                "description": "Optional custom window height."
              }
            },
            "required": [
              "value"
            ]
          },
          "description": "Quick-launch terminal command shortcuts."
        },
        "infinite-workspace.favorites.browserUrls": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "properties": {
              "value": {
                "type": "string",
                "description": "The URL to open."
              },
              "width": {
                "type": "number",
                "description": "Optional custom window width."
              },
              "height": {
                "type": "number",
                "description": "Optional custom window height."
              }
            },
            "required": [
              "value"
            ]
          },
          "description": "Quick-launch browser URL shortcuts."
        },
        "infinite-workspace.favorites.fileExplorerPaths": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "properties": {
              "value": {
                "type": "string",
                "description": "The file system path to open."
              },
              "width": {
                "type": "number",
                "description": "Optional custom window width."
              },
              "height": {
                "type": "number",
                "description": "Optional custom window height."
              }
            },
            "required": [
              "value"
            ]
          },
          "description": "Quick-launch file explorer path shortcuts."
        },
        "infinite-workspace.favorites.agentPaths": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "properties": {
              "value": {
                "type": "string",
                "description": "The working directory path for the agent."
              },
              "width": {
                "type": "number",
                "description": "Optional custom window width."
              },
              "height": {
                "type": "number",
                "description": "Optional custom window height."
              }
            },
            "required": [
              "value"
            ]
          },
          "description": "Quick-launch agent working directory shortcuts."
        }
      }
    }
  },
  "scripts": {
    "build": "npm run build:ext && npm run build:webview",
    "build:ext": "node esbuild.js",
    "build:webview": "vite build",
    "watch": "concurrently \"npm run watch:ext\" \"npm run watch:webview\"",
    "watch:ext": "node esbuild.js --watch",
    "watch:webview": "vite build --watch",
    "postinstall": "node -e \"const fs=require('fs'),p=require('path'),o=require('os'); if(o.platform()!=='win32'){const h=p.resolve(__dirname,'node_modules/node-pty/prebuilds',o.platform()+'-'+o.arch(),'spawn-helper'); if(fs.existsSync(h)){fs.chmodSync(h,0o755);console.log('Fixed spawn-helper permissions')}}\"",
    "vscode:prepublish": "npm run build",
    "package": "npx @vscode/vsce package",
    "publish:vscode": "npx @vscode/vsce publish",
    "publish:ovsx": "npx ovsx publish",
    "publish:all": "npm run publish:vscode && npm run publish:ovsx"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.3.0",
    "code-inspector-plugin": "^1.4.5",
    "concurrently": "^9.1.0",
    "esbuild": "^0.24.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.89",
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^5.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.469.0",
    "next-themes": "^0.4.6",
    "node-pty": "^1.0.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.0",
    "react-resizable-panels": "^4.8.0",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.0",
    "tw-animate-css": "^1.0.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  }
}